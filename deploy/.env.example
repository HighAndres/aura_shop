# Variables para docker-compose. Copiar a .env (en la carpeta deploy/).
# Postgres del propio stack:
POSTGRES_USER=aura
POSTGRES_PASSWORD=CAMBIA-ESTA-CONTRASENA
POSTGRES_DB=aura

# URL pública del API (tu subdominio + /api/v1). Se hornea en el build del front.
NEXT_PUBLIC_API_URL=https://aura.mirmiapps.com/api/v1
